{
  "name": "genie",
  "version": "0.1.0",
  "private": true,
  "description": "Genie — an open-source GitHub bot that turns demoable PRs into recorded demo videos.",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @genie/db generate",
    "db:migrate": "pnpm --filter @genie/db migrate"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.4.2"
    }
  }
}
