# ─── GitHub App ────────────────────────────────────────────────────────────────
# Create an App at https://github.com/settings/apps. Subscribe to: pull_request,
# issue_comment. Permissions: Pull requests R/W, Issues R/W, Contents R, Checks R/W.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=       # PEM contents (escape newlines as \n) or path via GITHUB_APP_PRIVATE_KEY_PATH
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# ─── AI providers (at least one) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Default model routing (overridable per-org/repo in the admin panel).
# Format: "<provider>:<model>"  where provider ∈ { anthropic, gemini }
GENIE_MODEL_TRIAGE=anthropic:claude-haiku-4-5
GENIE_MODEL_SCRIPT_GEN=anthropic:claude-sonnet-4-6
GENIE_MODEL_SUMMARIZE=anthropic:claude-haiku-4-5

# ─── Infra ─────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://genie:genie@localhost:5432/genie?schema=public
REDIS_URL=redis://localhost:6379

# Where recorded mp4s are uploaded for the "download" link. "release" uses a
# per-repo GitHub Release; "s3" uses an S3-compatible bucket (set the S3_* vars).
GENIE_MEDIA_BACKEND=release
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info
# Max self-heal regeneration attempts when a generated Playwright script fails.
GENIE_MAX_HEAL_ATTEMPTS=3
